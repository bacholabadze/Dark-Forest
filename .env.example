# Copy to `.env` (Vite loads VITE_* at build/dev time). All keys optional for a working demo.

# ── MAINNET READ (live Raydium tx stream → cyan trails + LIVE badge) ─────────
# Purpose: subscribe to Raydium DEX logs on Solana mainnet (read-only).
# Where:   https://dashboard.helius.dev → create free API key
# Optional: empty → procedural trails, badge shows STREAM OFFLINE
VITE_HELIUS_KEY=

# ── DEVNET WRITE (containment memo after you cage the bot) ───────────────────
# Purpose: write a Memo program tx on Solana DEVNET (never mainnet write).
# Where:   Solana CLI
#   solana-keygen new -o demo-keypair.json
#   solana airdrop 1 $(solana-keygen pubkey demo-keypair.json) --url devnet
# Paste the secret key JSON array from demo-keypair.json, e.g. [12,34,…]:
# Optional: empty → UI shows SIMULATED (demo still works)
VITE_SOLANA_SECRET=

# Devnet RPC for the containment write (default is fine)
VITE_DEVNET_RPC=https://api.devnet.solana.com

# ── OPTIONAL — Gemini Flash for live patrol-log narrator ─────────────────────
# Where: https://aistudio.google.com/apikey
# Prefer VITE_GEMINI_KEY; VITE_AI_KEY kept as alias.
# Without it the log uses the scripted corpus and says so.
VITE_GEMINI_KEY=
# VITE_AI_KEY=

# Demo pin: which sandwich case (0=MOON, 1=RAY, 2=ORCA). -1 = random.
# VITE_CASE_INDEX=0
